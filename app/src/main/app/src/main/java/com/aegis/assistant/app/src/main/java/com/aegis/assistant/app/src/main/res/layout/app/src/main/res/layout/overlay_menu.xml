<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC000000"
    android:padding="12dp"
    android:elevation="10dp">

    <TextView
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:text="⠿  VISUAL ASSIST  ⠿"
        android:textColor="#FF69B4"
        android:textSize="13sp"
        android:gravity="center"
        android:background="#44FFFFFF"
        android:padding="6dp"/>

    <Button
        android:id="@+id/btn_mode1"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:text="TRACKING A\nON"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:background="#00AA00"
        android:layout_marginTop="6dp"/>

    <Button
        android:id="@+id/btn_mode2"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:text="TRACKING B\nOFF"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:background="#AA0000"
        android:layout_marginTop="6dp"/>

    <Button
        android:id="@+id/btn_mode3"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:text="VISUAL GUIDE\nON"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:background="#00AA00"
        android:layout_marginTop="6dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="● ACTIVE — 2/3 modes ON"
        android:textColor="#00FF88"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:padding="4dp"
        android:background="#22FFFFFF"/>

</LinearLayout>
